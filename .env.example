# 舌镜 MCP Server 环境配置

# API配置
TONGUE_API_KEY=your_api_key_here
API_BASE_URL=https://api.example.com/v1

# 服务器配置
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# 日志配置
LOG_LEVEL=INFO

# ==========================================
# 正和系统积分配置（玄镜团队整合）
# ==========================================

# 正和API密钥（从正和MCP控制台获取）
ZHENGHE_API_KEY=sk_live_your_key_here

# 正和MCP服务地址
ZHENGHE_MCP_URL=http://localhost:8000/mcp
# 生产环境示例：
# ZHENGHE_MCP_URL=https://zhenghe-mcp.vercel.app/mcp

# 舌镜Agent ID（在正和系统注册的Agent）
TONGUE_AGENT_ID=agent_tongue_001

# 支付配置
# 是否启用积分支付（true/false）
PAYMENT_ENABLED=true

# 支付失败时是否降级为免费模式（true/false）
FALLBACK_TO_FREE=true
